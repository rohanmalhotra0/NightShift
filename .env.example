# NightShift Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./nightshift.db

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-api03-...

# 2Captcha (CAPTCHA solving)
TWOCAPTCHA_API_KEY=your_2captcha_api_key

# Google Services (paste JSON as single line)
GOOGLE_SHEETS_CREDENTIALS={"type": "service_account", ...}
GMAIL_CREDENTIALS={"installed": {"client_id": ..., "client_secret": ...}}

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Application Settings
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# LinkedIn (optional - for cookie-based auth)
LINKEDIN_COOKIES_PATH=./linkedin_cookies.json

# Scheduler
DEFAULT_RUN_HOUR_1=22
DEFAULT_RUN_HOUR_2=23
